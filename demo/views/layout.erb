<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= @page_title || "Trailhead — Sentiero Demo" %></title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 text-gray-800 min-h-screen">
  <!-- Shared nav: internal links feed track_navigation; the Guides link is
       external (different origin) to feed the external-navigation split. -->
  <nav class="bg-white border-b border-gray-200 sticky top-0 z-10">
    <div class="max-w-5xl mx-auto px-4 h-14 flex items-center gap-5">
      <a href="/" class="font-bold text-gray-900 mr-2">⛰️ Trailhead</a>
      <a href="/" class="text-sm text-gray-600 hover:text-gray-900">Landing</a>
      <a href="/signup" class="text-sm text-gray-600 hover:text-gray-900">Sign up</a>
      <a href="/app" class="text-sm text-gray-600 hover:text-gray-900">App</a>
      <a href="https://example.com" class="text-sm text-gray-600 hover:text-gray-900">Guides ↗</a>
      <span class="flex-1"></span>
      <a href="/sentiero/dashboard/" class="text-sm text-blue-600 hover:underline">Dashboard</a>
    </div>
  </nav>

  <% if @full_width %>
    <%= yield %>
  <% else %>
    <div class="max-w-2xl mx-auto px-4 py-10">
      <%= yield %>
    </div>
  <% end %>

  <%= sentiero_script_tag(events_url: "/sentiero/events") %>
</body>
</html>
