[
  { "name": "text: plain passes through", "op": "text", "config": {}, "input": "clicked the button", "expected": "clicked the button" },
  { "name": "text: email redacted", "op": "text", "config": {}, "input": "User alice@example.com not found", "expected": "User [redacted] not found" },
  { "name": "text: jwt redacted", "op": "text", "config": {}, "input": "token eyJhbGc.eyJzdWI.sig9_-x here", "expected": "token [redacted] here" },
  { "name": "text: long hex redacted (dashless uuid)", "op": "text", "config": {}, "input": "id 0123456789abcdef0123456789abcdef done", "expected": "id [redacted] done" },
  { "name": "text: card redacted", "op": "text", "config": {}, "input": "card 4111 1111 1111 1111 ok", "expected": "card [redacted] ok" },
  { "name": "text: url in text keeps path drops query", "op": "text", "config": {}, "input": "went to https://x.test/p?token=abc#frag next", "expected": "went to https://x.test/p next" },
  { "name": "text: disabled card keeps digits", "op": "text", "config": { "disabledPatterns": ["card"] }, "input": "card 4111 1111 1111 1111 ok", "expected": "card 4111 1111 1111 1111 ok" },
  { "name": "text: custom pattern redacts", "op": "text", "config": { "customPatterns": ["ACCT-\\d{6}"] }, "input": "ref ACCT-123456 end", "expected": "ref [redacted] end" },
  { "name": "url: strip default drops query and fragment", "op": "url", "config": {}, "input": "https://x.test/search?q=secret#sec", "expected": "https://x.test/search" },
  { "name": "url: strip leaves clean url", "op": "url", "config": {}, "input": "https://x.test/a/b", "expected": "https://x.test/a/b" },
  { "name": "url: keep_all verbatim", "op": "url", "config": { "urlMode": "keepAll" }, "input": "https://x.test/p?q=secret#f", "expected": "https://x.test/p?q=secret#f" },
  { "name": "url: keep_filtered keeps allowlisted drops denylisted filters rest", "op": "url", "config": { "urlMode": "keepFiltered", "urlParamAllowlist": ["utm_source"], "urlParamDenylist": ["token"] }, "input": "https://x.test/p?utm_source=google&token=abc&email=a@b.co", "expected": "https://x.test/p?utm_source=google&email=[redacted]" },
  { "name": "url: keep_filtered redacts fragment", "op": "url", "config": { "urlMode": "keepFiltered" }, "input": "https://x.test/p#alice@b.co", "expected": "https://x.test/p#[redacted]" },
  { "name": "url: non-string-safe malformed strip", "op": "url", "config": {}, "input": "not a url ? x # y", "expected": "not a url " },

  { "name": "custom_event: navigation maps url+text", "op": "custom_event", "config": {}, "input": { "type": 5, "data": { "tag": "navigation", "payload": { "url": "https://x.test/p?token=abc", "text": "mail a@b.co", "external": true } } }, "expected": { "type": 5, "data": { "tag": "navigation", "payload": { "url": "https://x.test/p", "text": "mail [redacted]", "external": true } } } },
  { "name": "custom_event: error maps message+stack(text) and source(url)", "op": "custom_event", "config": {}, "input": { "type": 5, "data": { "tag": "error", "payload": { "message": "fail a@b.co", "stack": "at https://x.test/s?k=1", "source": "https://x.test/app.js?token=abc", "lineno": 42 } } }, "expected": { "type": 5, "data": { "tag": "error", "payload": { "message": "fail [redacted]", "stack": "at https://x.test/s", "source": "https://x.test/app.js", "lineno": 42 } } } },
  { "name": "custom_event: __click maps selector(text)", "op": "custom_event", "config": {}, "input": { "type": 5, "data": { "tag": "__click", "payload": { "selector": "a@b.co" } } }, "expected": { "type": 5, "data": { "tag": "__click", "payload": { "selector": "[redacted]" } } } },
  { "name": "custom_event: __form_submit maps url", "op": "custom_event", "config": {}, "input": { "type": 5, "data": { "tag": "__form_submit", "payload": { "url": "https://x.test/f?secret=1", "form_id": "login" } } }, "expected": { "type": 5, "data": { "tag": "__form_submit", "payload": { "url": "https://x.test/f", "form_id": "login" } } } },
  { "name": "custom_event: unknown tag deep-redacts payload strings", "op": "custom_event", "config": {}, "input": { "type": 5, "data": { "tag": "whatever", "payload": { "x": "a@b.co" } } }, "expected": { "type": 5, "data": { "tag": "whatever", "payload": { "x": "[redacted]" } } } },
  { "name": "custom_event: known tag deep-redacts non-mapped field", "op": "custom_event", "config": {}, "input": { "type": 5, "data": { "tag": "navigation", "payload": { "url": "https://x.test/p", "note": "reach me at a@b.co", "external": true } } }, "expected": { "type": 5, "data": { "tag": "navigation", "payload": { "url": "https://x.test/p", "note": "reach me at [redacted]", "external": true } } } },
  { "name": "url: allowlisted built-in secret is still dropped", "op": "url", "config": { "urlMode": "keepFiltered", "urlParamAllowlist": ["token"] }, "input": "https://x.test/p?token=abc&page=2", "expected": "https://x.test/p?page=2" },

  { "name": "metadata: redacts url keys, leaves others", "op": "metadata", "config": {}, "input": { "url": "https://x.test/p?token=abc", "referrer": "https://r.test/?s=1", "entry_url": "https://x.test/start?k=1", "entry_referrer": "https://r.test/in?q=2", "userAgent": "UA/1.0", "viewport": "800x600" }, "expected": { "url": "https://x.test/p", "referrer": "https://r.test/", "entry_url": "https://x.test/start", "entry_referrer": "https://r.test/in", "userAgent": "UA/1.0", "viewport": "800x600" } },
  { "name": "metadata: non-url values are pattern-redacted, verbatim ids survive, nested values covered", "op": "metadata", "config": {}, "input": { "url": "https://x.test/p?token=abc", "note": "contact a@b.co", "plan": "pro", "operatorId": "abc123", "nested": { "hint": "card 4111 1111 1111 1111" } }, "expected": { "url": "https://x.test/p", "note": "contact [redacted]", "plan": "pro", "operatorId": "abc123", "nested": { "hint": "card [redacted]" } } },

  { "name": "url: keep_filtered percent-encoded value matching a pattern is redacted", "op": "url", "config": { "urlMode": "keepFiltered" }, "input": "https://x.test/p?email=user%40example.com", "expected": "https://x.test/p?email=[redacted]" },
  { "name": "url: keep_filtered percent-encoded value with no pattern match survives unmodified", "op": "url", "config": { "urlMode": "keepFiltered" }, "input": "https://x.test/p?q=hello%20world", "expected": "https://x.test/p?q=hello%20world" },
  { "name": "url: keep_filtered malformed percent-encoding survives unmodified", "op": "url", "config": { "urlMode": "keepFiltered" }, "input": "https://x.test/p?q=100%OFFsale", "expected": "https://x.test/p?q=100%OFFsale" },

  { "name": "custom_event: deep redact also redacts nested hash keys", "op": "custom_event", "config": {}, "input": { "type": 5, "data": { "tag": "whatever", "payload": { "meta": { "a@b.co": "clicked", "plan": "pro" } } } }, "expected": { "type": 5, "data": { "tag": "whatever", "payload": { "meta": { "[redacted]": "clicked", "plan": "pro" } } } } }
